<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".main_chapters.MainPractice">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="@color/black">

        <!-- Верхний декоративный фон -->
        <View
            android:id="@+id/imageView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/back"
            android:scaleType="fitXY"
            app:layout_constraintDimensionRatio="412:192"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Кнопка профиля -->
        <ImageButton
            android:id="@+id/profileBt"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="44dp"
            android:layout_marginEnd="16dp"
            android:background="@null"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_profile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Кнопка кода (компилятор) -->
        <ImageButton
            android:id="@+id/codeBt"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="44dp"
            android:background="@null"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_code"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Заголовок "Python" -->
        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="44dp"
            android:layout_marginEnd="16dp"
            android:text="@string/python"
            android:textAppearance="@style/some_id"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/imageView"
            app:layout_constraintStart_toStartOf="@id/imageView"
            app:layout_constraintTop_toTopOf="@id/imageView" />

        <!-- Переключатель вкладок (Теория / Практика / Описание) -->
        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="379dp"
            android:layout_height="49dp"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@+id/imageView"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_text"
            app:layout_constraintVertical_bias="0.578">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/programbt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/button_border_white"
                android:backgroundTint="@null"
                android:gravity="center"
                android:padding="16dp"
                android:text="Теория"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.3" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/cheatsbt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/button_border_black"
                android:backgroundTint="@null"
                android:gravity="center"
                android:padding="16dp"
                android:text="практика"
                android:textColor="#000000"
                android:textSize="11sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.3" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/descriptionbt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/button_border_white"
                android:backgroundTint="@null"
                android:gravity="center"
                android:padding="16dp"
                android:text="описание"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Прокручиваемый контейнер для списка заданий -->
        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scrollbars="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageView">

            <LinearLayout
                android:id="@+id/linearLayout2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F6F0FF"
                android:orientation="vertical"
                android:padding="8dp" />

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>